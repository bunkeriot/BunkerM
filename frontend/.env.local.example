# Auth (server-side only - never expose to client)
AUTH_SECRET=your-super-secret-jwt-key-change-this-in-production

# Set to 'true' ONLY when serving over HTTPS. Leave unset (or 'false') for HTTP
# deployments — setting this to 'true' on plain HTTP will silently break login.
# COOKIE_SECURE=false

# API Key shared with backend services (must match API_KEY in docker-compose)
NEXT_PUBLIC_API_KEY=your-api-key

# Version displayed in the UI
NEXT_PUBLIC_CURRENT_VERSION=v2.1.0

# --- Local dev only (outside Docker) ---
# Uncomment these ONLY when running "npm run dev" directly against a running container.
# Inside Docker, the defaults (/api/dynsec, /api/monitor, etc.) are used via Nginx.
# NEXT_PUBLIC_DYNSEC_API_URL=http://localhost:2001
# NEXT_PUBLIC_MONITOR_API_URL=http://localhost:2002
# NEXT_PUBLIC_AWS_BRIDGE_API_URL=http://localhost:2003
# NEXT_PUBLIC_AZURE_BRIDGE_API_URL=http://localhost:2004
# NEXT_PUBLIC_CLIENTLOGS_API_URL=http://localhost:2005
# NEXT_PUBLIC_CONFIG_API_URL=http://localhost:2006
