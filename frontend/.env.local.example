# Auth (server-side only - never expose to client)
AUTH_SECRET=your-super-secret-jwt-key-change-this-in-production

# API URLs (client-side accessible)
NEXT_PUBLIC_DYNSEC_API_URL=http://localhost:2001
NEXT_PUBLIC_MONITOR_API_URL=http://localhost:2002
NEXT_PUBLIC_AWS_BRIDGE_API_URL=http://localhost:2003
NEXT_PUBLIC_API_KEY=your-api-key

# Optional
NEXT_PUBLIC_HOST_ADDRESS=localhost
NEXT_PUBLIC_CURRENT_VERSION=v2.0.0
